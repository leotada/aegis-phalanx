# Authentication and bot configuration
GITHUB_TOKEN=your_github_token_here
TELEGRAM_BOT_TOKEN=12345:AABBBCCC
TELEGRAM_CHAT_ID=123456789

# Optional: Default GitHub repository to target if not specified in the demand (leave blank to require explicit prefixes)
DEFAULT_REPO=

# Agent CLI tool for all pipeline steps (agy | cursor | claude | aider)
# Controls image build, credential mounts, and pipeline execution
AGENT_TOOL=agy

# Timeouts for the agent CLI execution (s=seconds, m=minutes)
AGENT_STEP_TIMEOUT=5m
AGENT_INTENT_TIMEOUT=15s

# Optional: Cursor API key fallback when session login is not mounted
# Preferred auth is `agent login` on the host (see README)
# Create a key at https://cursor.com/dashboard/integrations
CURSOR_API_KEY=

# Optional: Path to SSH Agent socket for Git/GitHub SSH authentication inside the container
# SSH_AUTH_SOCK=/run/user/1000/gnupg/S.gpg-agent.ssh

